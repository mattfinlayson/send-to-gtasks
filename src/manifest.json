{
  "manifest_version": 3,
  "name": "Send to Google Tasks",
  "version": "1.0.0",
  "description": "Quickly save any web page as a task in Google Tasks with a single click",
  "permissions": [
    "activeTab",
    "storage",
    "identity",
    "alarms"
  ],
  "oauth2": {
    "client_id": "826876690942-meimo9nertd9kah0ftmk16kk15adl5ma.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/tasks"
    ]
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Save page to Google Tasks",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "options_page": "src/options/options.html"
}
